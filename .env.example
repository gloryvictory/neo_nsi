# ═══════════════════════════════════════════════
# Конфигурация подключения к PostgreSQL
# Скопируйте этот файл в .env и заполните данные
# ═══════════════════════════════════════════════

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=your_database
DB_SCHEMA=public

# Префикс таблиц для поиска (по умолчанию "Справочник")
TABLE_PREFIX=Справочник

# Порт сервера API
SERVER_PORT=3001

# Порт dev-сервера Vite
VITE_PORT=5173